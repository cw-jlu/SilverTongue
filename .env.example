# SilverTongue 环境变量 — 复制为 .env 后填入真实值
# .env 已加入 .gitignore，不会提交到仓库

# ===== MySQL =====
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_DB=silvertongue
MYSQL_USER=changeme
MYSQL_PASSWORD=changeme

# ===== Redis =====
REDIS_HOST=redis
REDIS_PORT=6379

# ===== Elasticsearch =====
ES_URIS=http://elasticsearch:9200

# ===== MinIO =====
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=changeme
MINIO_SECRET_KEY=changeme

# ===== gRPC Agent =====
GRPC_AGENT_HOST=ai-agent
GRPC_AGENT_PORT=50051

# ===== JWT =====
JWT_SECRET=changeme

# ===== WeChat OAuth2 (必填，否则微信登录不可用) =====
WECHAT_APP_ID=changeme
WECHAT_APP_SECRET=changeme
